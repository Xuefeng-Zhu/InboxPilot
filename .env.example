# =============================================================================
# InboxPilot — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for local development.
# Never commit .env.local or any file containing real secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# InsForge
# ---------------------------------------------------------------------------
NEXT_PUBLIC_INSFORGE_URL=https://y39ezar3.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your-insforge-anon-key
INSFORGE_SERVICE_ROLE_KEY=your-insforge-service-role-key

# ---------------------------------------------------------------------------
# AI / LLM (OpenRouter)
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini

# ---------------------------------------------------------------------------
# SMS Providers
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TELNYX_API_KEY=your-telnyx-api-key

# ---------------------------------------------------------------------------
# Email Providers
# ---------------------------------------------------------------------------
POSTMARK_SERVER_TOKEN=your-postmark-server-token

# ---------------------------------------------------------------------------
# Internal dispatch token (CRITICAL-4)
# ---------------------------------------------------------------------------
# Shared secret required in the `x-internal-token` header for the
# internal-dispatch function entrypoints (process-knowledge-document,
# process-ai-job, process-jobs). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be >= 64 hex chars (32 random bytes). Rotate periodically.
# Set this in the InsForge function secret store for production; the value
# below is a placeholder for local dev only.
INTERNAL_DISPATCH_TOKEN=replace-with-32-random-bytes-hex
