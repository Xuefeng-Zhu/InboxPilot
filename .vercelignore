# Build artifacts — regenerated by Vercel during build
.next/
out/
dist/

# Dependencies — Vercel runs `npm install` itself
node_modules/
widget-src/node_modules/
widget-src/dist/

# Vercel cache
.vercel

# Vercel-specific files
*.tsbuildinfo
next-env.d.ts

# Environment (InsForge injects these via `deployments env set`)
.env
.env.local
.env.*.local

# IDE / agent metadata (no impact on build)
.DS_Store
.idea/
.vscode/

# AI agent skill caches (no impact on build)
.insforge/
.agent/
.agents/
.augment/
.claude/
.cline/
.kilocode/
.omo/
.qa/
.qoder/
.qwen/
.roo/
.trae/
.windsurf/
.kiro/

# MCP / Playwright artifacts
page-*.png
page-*.jpeg
page-*.webp
console-*.log
.playwright-mcp/
/playwright-cli-output/
.playwright-cli/
*.playwright-temp

# Test outputs
playwright-report/
test-results/
coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Git
.git/
.gitignore

# public/widget.js is committed and is uploaded as a fallback in case
# `build:widget` ever fails. Vercel rebuilds the widget on every deploy
# via `vercel.json` (`buildCommand: npm run build`), so the committed copy
# is normally overwritten by the fresh build.
