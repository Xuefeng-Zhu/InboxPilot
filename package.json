{
  "name": "inboxpilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:widget && next build",
    "build:widget": "cd widget-src && npm run build",
    "start": "next start",
    "lint": "tsc --noEmit && npm run lint:deno",
    "lint:deno": "node scripts/check-deno-safety.mjs && deno check insforge/functions/*/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:core": "vitest run packages/support-core/__tests__"
  },
  "dependencies": {
    "@inboxpilot/support-core": "file:packages/support-core",
    "@insforge/sdk": "^1.2.5",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.101.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.19",
    "fast-check": "^3.19.0",
    "jsdom": "^29.1.1",
    "pg": "^8.21.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
