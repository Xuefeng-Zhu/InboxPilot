{
  "name": "inboxpilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "tunnel": "node scripts/tunnel.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:core": "vitest run --project support-core",
    "test:webhook-tunnel": "vitest run __tests__/twilio-webhook-tunnel.test.ts",
    "test:rotation": "vitest run packages/support-core/__tests__/unit/sms-provider-credential-rotation.test.ts",
    "perf:api": "bash scripts/api-perf.sh",
    "perf:lighthouse": "lhci autorun --config=./lighthouserc.cjs",
    "perf": "npm run perf:api && npm run perf:lighthouse"
  },
  "dependencies": {
    "@insforge/sdk": "^1.2.5",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "fast-check": "^3.19.0",
    "localtunnel": "^2.0.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
